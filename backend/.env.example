# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/vr-escape-room
# Alternatively use MongoDB Atlas:
# MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# Authentication & Security
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_EXPIRATION=7d
PASSPORT_SECRET=your_passport_secret_key_here
BCRYPT_ROUNDS=10

# API & CORS
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# DocuSign (E-Signatures) - Optional for MVP
DOCUSIGN_ENABLED=false
DOCUSIGN_ACCOUNT_ID=your_account_id
DOCUSIGN_CLIENT_ID=your_client_id
DOCUSIGN_CLIENT_SECRET=your_client_secret
DOCUSIGN_AUTH_SERVER=https://account-d.docusign.com
DOCUSIGN_TEMPLATE_ID=your_template_id

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@vrescape.com

# AWS (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
